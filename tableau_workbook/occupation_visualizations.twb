    <dashboard name='occ Story 1' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Shifting Landscapes of Degree-Driven Employment: A Decade of Redistribution</run>
          </formatted-text>
