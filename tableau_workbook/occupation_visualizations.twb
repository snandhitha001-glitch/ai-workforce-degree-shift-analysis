      <column caption='Employment 2021' datatype='real' name='[2011 Employment (copy)_1053842319441006595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Geography Name], [Occupation], [Sheet] : &#13;&#10;  SUM(IF [Year] = 2021 THEN [Employment] END) }' />
