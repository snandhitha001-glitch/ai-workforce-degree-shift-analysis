      <column caption='AI_Prone_Percentage' datatype='real' default-format='p0.00%' name='[AI_Prone_Employment (copy)_805581389943926785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Degree_Heavy_Employment (copy)_805581389943746560] / [All]' />
      </column>
      <column caption='Agriculture Energy' datatype='real' name='[Agriculture_Energy]' role='measure' type='quantitative' />
      <column caption='Bng E' datatype='integer' name='[BNG_E]' role='measure' type='quantitative' />
