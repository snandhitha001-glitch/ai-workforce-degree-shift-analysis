      <column caption='AI_Prone_Percentage' datatype='real' default-format='p0.00%' name='[AI_Prone_Employment (copy)_805581389943926785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Degree_Heavy_Employment (copy)_805581389943746560] / [All]' />
      </column>
      <column caption='Agriculture Energy' datatype='real' name='[Agriculture_Energy]' role='measure' type='quantitative' />
      <column caption='Bng E' datatype='integer' name='[BNG_E]' role='measure' type='quantitative' />
      <column caption='Bng N' datatype='integer' name='[BNG_N]' role='measure' type='quantitative' />
      <column caption='Degree_Heavy_Employment' datatype='real' name='[Calculation_1005147148255887360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Public_Admin_Education_Health] + [Finance_RealEstate_ProfTech]' />
      </column>
      <column caption='Degree_Heavy_Percentage' datatype='real' default-format='p0.00%' name='[Calculation_1005147148282052610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1005147148255887360] / [All]' />
      </column>
      <column caption='Finance_2011' datatype='real' name='[Calculation_805581389948850179]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Year] = 2011 THEN [Finance_RealEstate_ProfTech] END' />
      </column>
      <column caption='Growth' datatype='real' default-format='p0.00%' name='[Calculation_805581389951033351]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(&#13;&#10;IF [Year] = 2021 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)&#13;&#10;-&#13;&#10;SUM(&#13;&#10;IF [Year] = 2011 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)) / SUM(&#13;&#10;IF [Year] = 2011 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)' />
      </column>
      <column caption='AI_Prone_Employment' datatype='real' name='[Degree_Heavy_Employment (copy)_805581389943746560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Manufacturing] + [Transport_Communication] + [Finance_RealEstate_ProfTech]' />
      </column>
      <column caption='Distribution Hotels' datatype='real' name='[Distribution_Hotels]' role='measure' type='quantitative' />
      <column caption='Finance_2021' datatype='real' name='[Finance_2011 (copy)_805581389948915716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Year] = 2021 THEN [Finance_RealEstate_ProfTech] END' />
      </column>
      <column caption='Finance RealEstate ProfTech' datatype='real' name='[Finance_RealEstate_ProfTech]' role='measure' type='quantitative' />
