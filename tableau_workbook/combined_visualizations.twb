    <worksheet name='ind 9'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000'>Hotspots of Knowledge-Economy Growth: Are Degrees Still Driving It?</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='industry_by_age_cleaned' name='federated.1or3uzr1ltzw2z1gux63k1hcwfbx' />
            <datasource caption='qualification_by_sex_cleaned' name='federated.14cl57i1jtnlgu119yec00z4z8od' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.14cl57i1jtnlgu119yec00z4z8od'>
            <column datatype='integer' name='[Year]' role='dimension' type='ordinal' />
            <column-instance column='[Year]' derivation='None' name='[none:Year:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1or3uzr1ltzw2z1gux63k1hcwfbx'>
            <column caption='Growth' datatype='real' default-format='p0.00%' name='[Calculation_805581389951033351]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM(&#13;&#10;IF [Year] = 2021 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)&#13;&#10;-&#13;&#10;SUM(&#13;&#10;IF [Year] = 2011 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)) / SUM(&#13;&#10;IF [Year] = 2011 THEN [Finance_RealEstate_ProfTech] END&#13;&#10;)' />
            </column>
            <column caption='Finance RealEstate ProfTech' datatype='real' name='[Finance_RealEstate_ProfTech]' role='measure' type='quantitative' />
            <column datatype='string' name='[Geography Name]' role='dimension' semantic-role='[County].[Name]' type='nominal' />
