          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0arztsx0wv8urt12ila9i033i6jc'>
            <column datatype='integer' name='[All]' role='measure' type='quantitative' />
            <column caption='Male Finance_RealEstate_ProfTech' datatype='real' name='[Calculation_805581389954056201]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// % Male&#13;&#10;IF [Sheet] = &quot;Males&quot; THEN [Finance_RealEstate_ProfTech] / [All] END' />
            </column>
            <column caption=' Gender_Disparity_Percentage Finance_RealEstate_ProfTech' datatype='real' default-format='p0.00%' name='[Female Percentage Finance_RealEstate_ProfTech (copy)_805581389954420747]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_805581389954056201]) - SUM([Male Percentage Finance_RealEstate_ProfTech (copy)_805581389954269194])' />
            </column>
            <column caption='Finance RealEstate ProfTech' datatype='integer' name='[Finance_RealEstate_ProfTech]' role='measure' type='quantitative' />
            <column datatype='string' name='[Geography Name]' role='dimension' type='nominal' />
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column caption='Female Finance_RealEstate_ProfTech' datatype='real' name='[Male Percentage Finance_RealEstate_ProfTech (copy)_805581389954269194]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// % Female&#13;&#10;IF [Sheet] = &quot;Females&quot; THEN [Finance_RealEstate_ProfTech] / [All] END' />
