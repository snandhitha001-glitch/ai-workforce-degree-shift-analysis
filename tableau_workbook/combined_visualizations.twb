                  <story-point caption='Regional Education Divide' captured-sheet='qual 5' id='3' />
                  <story-point caption='Tracking Progress: Who’s Advancing Faster — Men or Women?' captured-sheet='qual 6' id='4'>
                    <capturedDeltas>
                      <worksheet name='qual 6'>
                        <annotations>
                          <annotation class='area' delta-type='added' id='0' text-pinx='0.5' text-piny='0.5' text-width-delta='19'>
