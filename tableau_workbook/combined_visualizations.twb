    <worksheet name='ind 7'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000'>How Dependent Are Regions on Degrees? % Employed in Health, Education &amp; ProfTech</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='industry_by_age_cleaned' name='federated.1or3uzr1ltzw2z1gux63k1hcwfbx' />
            <datasource caption='qualification_by_sex_cleaned' name='federated.14cl57i1jtnlgu119yec00z4z8od' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.14cl57i1jtnlgu119yec00z4z8od'>
            <column datatype='integer' name='[Year]' role='dimension' type='ordinal' />
            <column-instance column='[Year]' derivation='None' name='[none:Year:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1or3uzr1ltzw2z1gux63k1hcwfbx'>
            <column datatype='string' name='[Age Group]' role='dimension' type='nominal' />
            <column datatype='real' name='[All]' role='measure' type='quantitative' />
            <column caption='Degree_Heavy_Employment' datatype='real' name='[Calculation_1005147148255887360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Public_Admin_Education_Health] + [Finance_RealEstate_ProfTech]' />
            </column>
            <column caption='Degree_Heavy_Percentage' datatype='real' default-format='p0.00%' name='[Calculation_1005147148282052610]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1005147148255887360] / [All]' />
