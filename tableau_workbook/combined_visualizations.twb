    <worksheet name='ind 10'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000'>Gender Disparity in Finance &amp; Professional Employment</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='industry_by_sex_cleaned.csv+ (Multiple Connections)' name='federated.0arztsx0wv8urt12ila9i033i6jc' />
            <datasource caption='qualification_by_sex_cleaned' name='federated.14cl57i1jtnlgu119yec00z4z8od' />
