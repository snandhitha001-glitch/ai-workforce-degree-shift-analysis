                          <annotation class='area' delta-type='added' id='1' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                            <formatted-text>
                              <run bold='true' fontalignment='2' fontcolor='#000000' fontsize='8'>Gap persists at the lower end</run>
                              <run fontalignment='2' fontcolor='#000000' fontsize='8'> — nearly </run>
                              <run bold='true' fontalignment='2' fontcolor='#000000' fontsize='8'>800K more</run>
                              <run fontalignment='2' fontcolor='#000000' fontsize='8'> women than men still have no qualifications. </run>
                            </formatted-text>
                            <top-left>
                              <visual-coordinate class='axis'>
